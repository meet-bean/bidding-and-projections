{
  "permissions": {
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      },
      "autoUpdate": true
    }
  },
  "skipAutoPermissionPrompt": true,
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Context is being compacted. If meaningful progress was made this session, update CLAUDE.md (## Current State) so it survives.'"
          }
        ]
      }
    ]
  }
}
